<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 常時電源接続プロファイルがPARTIAL_WAKE_LOCKでスリープを防ぐために
         必要。省電力/通常プロファイルでは取得しない(PowerProfile.kt参照、
         open-web-server/android版と同じパターン)。 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- ACTION_POWER_DISCONNECTED/CONNECTEDはprotected broadcastのため、
         マニフェスト側の権限宣言は不要(コード側でreceiverを動的登録)。 -->

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_normal"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AruaruDb"
        android:usesCleartextTraffic="true">

        <!--
          起動時の電源プロファイル選択画面をLAUNCHERにする
          (open-web-server/android版と同じ構成)。
        -->
        <activity
            android:name=".ProfileSelectActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          aruaru-dbクラスタへのリモート接続先設定+ヘルスチェック/ステータス
          表示を行うメイン画面。サーバー本体はこのアプリ上では一切起動しない
          (リモート管理クライアントとして設計、../CLAUDE.md参照)。
        -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!--
          3電源プロファイルそれぞれの専用ホーム画面アイコン
          (open-web-server/android版と同じパターン)。
        -->
        <activity-alias
            android:name=".LauncherPowerSave"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_powersave"
            android:label="@string/app_name_powersave"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.aruarudb.LAUNCH_POWER_SAVE" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherNormal"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_normal"
            android:label="@string/app_name_normal"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.aruarudb.LAUNCH_NORMAL" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherAlwaysOn"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_alwayson"
            android:label="@string/app_name_alwayson"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.aruarudb.LAUNCH_ALWAYS_ON" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>

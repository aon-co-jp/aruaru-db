# aruaru-DB Admin Web — 環境変数テンプレート
#
# 案Z: aruaru-server 直接接続。将来 Hive Gateway に切替可能。
#
# 開発時 (既定)
# VITE_ARUARU_GQL_ENDPOINT=http://localhost:4000/graphql
#
# 本番時 (Hive Gateway 差し込み例)
# VITE_ARUARU_GQL_ENDPOINT=https://hive.example.com/graphql
#
# PWA ビルドで必要な公開 URL
# VITE_PUBLIC_URL=https://admin.example.com
VITE_ARUARU_GQL_ENDPOINT=http://localhost:4000/graphql
